<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">


    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="44dp"
        android:background="#E2819F"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/tvHomePage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    </LinearLayout>

    <ImageView
        android:id="@+id/ivLogoPic"
        android:layout_width="100dp"
        android:layout_height="0dp"
        android:layout_marginTop="55dp"
        android:layout_marginBottom="116dp"
        app:layout_constraintBottom_toTopOf="@+id/btnsu"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/almalogopic" />

    <TextView
        android:id="@+id/tvHomePage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="49dp"
        android:fontFamily="serif"
        android:text="דף הבית"
        android:textColor="#E2819F"
        android:textSize="50dp"
        app:layout_constraintBottom_toTopOf="@+id/btnsu"
        app:layout_constraintStart_toStartOf="@+id/btnsu"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout2" />

    <Button
        android:id="@+id/btnsu"
        android:layout_width="184dp"
        android:layout_height="0dp"
        android:layout_marginBottom="382dp"
        android:backgroundTint="#E2819F"
        android:text="הירשם"
        android:textSize="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivLogoPic" />

    <Button
        android:id="@+id/btnli"
        android:layout_width="184dp"
        android:layout_height="0dp"
        android:layout_marginBottom="9dp"
        android:backgroundTint="#E2819F"
        android:text="התחבר"
        android:textSize="20dp"
        app:layout_constraintBottom_toTopOf="@+id/btna"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnsu" />

    <Button
        android:id="@+id/btna"
        android:layout_width="184dp"
        android:layout_height="0dp"
        android:layout_marginBottom="156dp"
        android:backgroundTint="#E2819F"
        android:text="אודות"
        android:textSize="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnli" />


